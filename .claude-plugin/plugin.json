{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "agent-dev",
  "displayName": "Agent Dev",
  "version": "0.1.0",
  "description": "A plugin to help with agent development and testing.",
  "license": "MIT",
  "author": {
    "name": "j0hanz"
  },
  "repository": "https://github.com/j0hanz/agent-dev",
  "homepage": "https://github.com/j0hanz/agent-dev#readme",
  "keywords": ["agent-dev", "claude", "plugin", "agent", "development", "testing"],
  "hooks": "./hooks/hooks.json",
  "experimental": {
    "monitors": "./monitors/monitors.json"
  },
  "userConfig": {
    "brainstorm_nudge": {
      "type": "boolean",
      "title": "Brainstorm nudge",
      "description": "Remind to brainstorm before implementing on UserPromptSubmit",
      "default": true
    },
    "skills_announce": {
      "type": "boolean",
      "title": "Skills routing guide",
      "description": "Inject the skill routing guide into context at SessionStart",
      "default": true
    },
    "telemetry_enabled": {
      "type": "boolean",
      "title": "Hook telemetry",
      "description": "Write hook execution timings to .claude/telemetry.log",
      "default": true
    }
  }
}
