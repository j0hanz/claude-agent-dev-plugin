{
  "alwaysThinkingEnabled": true,
  "cleanupPeriodDays": 7,
  "defaultShell": "powershell",
  "spinnerTipsEnabled": true,
  "permissions": {
    "allow": [
      "Bash(node --version:*)",
      "Bash(node --test:*)",
      "Bash(npm list:*)",
      "Bash(npm view:*)",
      "Bash(npm outdated:*)",
      "Bash(npm run lint:*)",
      "Bash(npm run format:check:*)",
      "Bash(npm test:*)",
      "Bash(python --version:*)",
      "Bash(python3 --version:*)",
      "Bash(python -m pytest:*)",
      "Bash(ruff check:*)",
      "Bash(ruff --version:*)",
      "PowerShell(node --version:*)",
      "PowerShell(node --test:*)",
      "PowerShell(npm list:*)",
      "PowerShell(npm view:*)",
      "PowerShell(npm outdated:*)",
      "PowerShell(npm run lint:*)",
      "PowerShell(npm run format:check:*)",
      "PowerShell(npm test:*)",
      "PowerShell(python --version:*)",
      "PowerShell(python3 --version:*)",
      "PowerShell(python -m pytest:*)",
      "PowerShell(ruff check:*)",
      "PowerShell(ruff --version:*)"
    ],
    "additionalDirectories": ["C:\\agent-dev"],
    "defaultMode": "acceptEdits"
  },
  "sandbox": {
    "enabled": true
  },
  "env": {
    "MAX_THINKING_TOKENS": "16000"
  }
}
